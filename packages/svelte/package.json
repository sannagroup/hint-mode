{
  "name": "@sannagroup/hint-mode-svelte",
  "version": "0.1.0",
  "description": "Svelte 5 adapter for @sannagroup/hint-mode.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && svelte-package",
    "test": "vitest run",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "keywords": [
    "svelte",
    "vimium",
    "keyboard",
    "hint",
    "navigation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sannagroup/hint-mode.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/sannagroup/hint-mode/tree/main/packages/svelte#readme",
  "bugs": "https://github.com/sannagroup/hint-mode/issues",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@sannagroup/hint-mode": "workspace:*",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.7",
    "@testing-library/svelte": "^5.2.6",
    "@types/jsdom": "^21.1.7",
    "jsdom": "^25.0.1",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "vite": "^6.0.0"
  }
}
