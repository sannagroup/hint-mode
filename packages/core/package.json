{
  "name": "@sannagroup/hint-mode",
  "version": "0.1.0",
  "description": "Vimium-style keyboard hint navigation for any web page. Pure JS / TypeScript core.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp src/style.css dist/style.css",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "keywords": [
    "vimium",
    "keyboard",
    "hint",
    "accessibility",
    "navigation",
    "shortcuts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sannagroup/hint-mode.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sannagroup/hint-mode/tree/main/packages/core#readme",
  "bugs": "https://github.com/sannagroup/hint-mode/issues",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
